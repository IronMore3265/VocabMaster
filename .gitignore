# dependencies
node_modules/

# build output
dist/

# local env files
.env
.env*.local

# The Capacitor Android project IS tracked so release builds (versionName, native
# plugins, manifest) are reproducible. Build artifacts, keystores and the copied
# web assets are excluded by android/.gitignore.

# release signing keystore (keep a private backup!)
*.keystore
*.jks

# Store-listing screenshot editor (scaffolded by the app-store-screenshots skill
# into store-screenshots/). The Next.js editor is disposable — re-scaffold it from
# the skill instead of tracking it. Only the exported images are committed.
store-screenshots/*
!store-screenshots/exports/

# logs / debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
